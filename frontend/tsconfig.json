{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    // ลบ "jsx": "react-jsx" เพราะโปรเจกต์นี้เป็น Vue 3 (ใช้ .vue SFC ไม่ใช่ JSX)
    "strict": true,
    "noUnusedLocals": true,  // เปลี่ยนเป็น true เพื่อ strict มากขึ้น
    "noUnusedParameters": true,  // เปลี่ยนเป็น true
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "allowJs": true,  // เพิ่มเพื่อรองรับไฟล์ .js ที่ใช้งานร่วมกับ .vue/.ts
    "esModuleInterop": true,  // เพิ่มสำหรับ import modules
    "types": ["vite/client"]  // เพิ่มสำหรับ Vite env types
  },
  "include": ["src/**/*"],
  "references": [{ "path": "./tsconfig.node.json" }]
}